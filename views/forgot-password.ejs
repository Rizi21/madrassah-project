<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="login-shell">
    <main class="center-panel">
      <p class="eyebrow">Password reset</p>
      <h1>Reset your password</h1>
      <p class="hero-copy">For this local MVP, the reset link is shown on screen. In production, this would be emailed.</p>

      <% if (error) { %>
        <div class="banner error"><%= error %></div>
      <% } %>

      <% if (notice) { %>
        <div class="banner notice"><%= notice %></div>
      <% } %>

      <% if (resetLink) { %>
        <div class="detail-block">
          <h2>Local reset link</h2>
          <p><a href="<%= resetLink %>"><%= resetLink %></a></p>
        </div>
      <% } %>

      <form method="post" action="/forgot-password" class="stack">
        <label>
          <span>Email</span>
          <input type="email" name="email" required />
        </label>
        <button class="primary-button" type="submit">Generate reset link</button>
      </form>

      <p class="auth-links"><a href="/">Back to login</a></p>
    </main>
  </body>
</html>
