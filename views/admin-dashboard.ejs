<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <div class="brand-lockup">
        <% if (tenant.logoPath) { %>
          <img class="tenant-logo" src="<%= tenant.logoPath %>" alt="<%= tenant.displayName %> logo" />
        <% } %>
        <div>
          <p class="eyebrow">Masjid Admin</p>
          <h1><%= dashboard.organizationName %></h1>
          <p class="muted">Signed in as <strong><%= user.name %></strong></p>
        </div>
      </div>
      <form method="post" action="/logout">
        <button class="ghost-button" type="submit">Log out</button>
      </form>
    </header>

    <main class="dashboard-shell">
      <% if (notice) { %>
        <div class="banner notice"><%= notice %></div>
      <% } %>

      <% if (error) { %>
        <div class="banner error"><%= error %></div>
      <% } %>

      <section class="summary-row">
        <article class="summary-card">
          <span>Users</span>
          <strong><%= dashboard.users.length %></strong>
        </article>
        <article class="summary-card">
          <span>Pending approval</span>
          <strong><%= dashboard.pendingUsers.length %></strong>
        </article>
        <article class="summary-card">
          <span><%= tenant.terminology.teacher %>s</span>
          <strong><%= dashboard.teachers.length %></strong>
        </article>
        <article class="summary-card">
          <span>Classes</span>
          <strong><%= dashboard.classGroups.length %></strong>
        </article>
      </section>

      <% if (dashboard.pendingUsers.length > 0) { %>
        <section class="form-card form-card-wide">
          <h2>Pending signups</h2>
          <p class="muted">Approve people who signed up with the masjid code and assign their correct role.</p>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Assign role</th>
                </tr>
              </thead>
              <tbody>
                <% dashboard.pendingUsers.forEach((account) => { %>
                  <tr>
                    <td><%= account.name %></td>
                    <td><%= account.email %></td>
                    <td>
                      <form method="post" action="/admin/users/<%= account.id %>/approve" class="inline-form">
                        <select name="role" required>
                          <option value="teacher"><%= tenant.terminology.teacher %></option>
                          <option value="parent"><%= tenant.terminology.parent %></option>
                          <option value="admin">Admin</option>
                        </select>
                        <button class="primary-button" type="submit">Approve</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      <% } %>

      <section class="forms-grid">
        <article class="form-card">
          <h2>Create user</h2>
          <p class="muted">Create admin, <%= tenant.terminology.teacher.toLowerCase() %>, or <%= tenant.terminology.parent.toLowerCase() %> accounts for this masjid.</p>
          <form method="post" action="/admin/users" class="stack">
            <label>
              <span>Name</span>
              <input type="text" name="name" placeholder="Full name" required />
            </label>
            <label>
              <span>Email</span>
              <input type="email" name="email" placeholder="name@example.com" required />
            </label>
            <label>
              <span>Role</span>
              <select name="role" required>
                <option value="teacher"><%= tenant.terminology.teacher %></option>
                <option value="parent"><%= tenant.terminology.parent %></option>
                <option value="admin">Admin</option>
              </select>
            </label>
            <label>
              <span>Initial password</span>
              <input type="password" name="password" value="Password123!" required />
            </label>
            <button class="primary-button" type="submit">Create user</button>
          </form>
        </article>

        <article class="form-card">
          <h2>Create student</h2>
          <p class="muted">Link each student to one <%= tenant.terminology.teacher.toLowerCase() %> and one <%= tenant.terminology.parent.toLowerCase() %>.</p>
          <% if (dashboard.teachers.length === 0 || dashboard.guardians.length === 0) { %>
            <div class="banner error">Create at least one <%= tenant.terminology.teacher.toLowerCase() %> and one <%= tenant.terminology.parent.toLowerCase() %> first.</div>
          <% } else { %>
            <form method="post" action="/admin/students" class="stack">
              <label>
                <span>First name</span>
                <input type="text" name="firstName" required />
              </label>
              <label>
                <span>Last name</span>
                <input type="text" name="lastName" required />
              </label>
              <label>
                <span><%= tenant.terminology.teacher %></span>
                <select name="teacherUserId" required>
                  <% dashboard.teachers.forEach((teacher) => { %>
                    <option value="<%= teacher.id %>"><%= teacher.name %></option>
                  <% }) %>
                </select>
              </label>
              <label>
                <span><%= tenant.terminology.parent %></span>
                <select name="guardianUserId" required>
                  <% dashboard.guardians.forEach((guardian) => { %>
                    <option value="<%= guardian.id %>"><%= guardian.name %></option>
                  <% }) %>
                </select>
              </label>
              <label>
                <span>Current surah</span>
                <input type="text" name="currentSurah" placeholder="Surah Al-Mulk" required />
              </label>
              <label>
                <span>Current ayah</span>
                <input type="text" name="currentAyah" placeholder="Ayah 1" required />
              </label>
              <label>
                <span>Monthly fee</span>
                <input type="number" name="monthlyFee" min="0" step="0.01" value="<%= tenant.feeDefaults.monthlyAmount %>" required />
              </label>
              <button class="primary-button" type="submit">Create student</button>
            </form>
          <% } %>
        </article>
      </section>

      <section class="forms-grid">
        <article class="form-card">
          <h2>Create class</h2>
          <p class="muted">Create a class or group and assign one <%= tenant.terminology.teacher.toLowerCase() %> to it.</p>
          <% if (dashboard.teachers.length === 0) { %>
            <div class="banner error">Create at least one <%= tenant.terminology.teacher.toLowerCase() %> first.</div>
          <% } else { %>
            <form method="post" action="/admin/classes" class="stack">
              <label>
                <span>Class name</span>
                <input type="text" name="name" placeholder="Weekday Hifz Group" required />
              </label>
              <label>
                <span>Description</span>
                <textarea name="description" rows="3" placeholder="Days, level, or notes for this class"></textarea>
              </label>
              <label>
                <span><%= tenant.terminology.teacher %></span>
                <select name="teacherUserId" required>
                  <% dashboard.teachers.forEach((teacher) => { %>
                    <option value="<%= teacher.id %>"><%= teacher.name %></option>
                  <% }) %>
                </select>
              </label>
              <button class="primary-button" type="submit">Create class</button>
            </form>
          <% } %>
        </article>

        <article class="form-card">
          <h2>Assign student to class</h2>
          <p class="muted">Use this to group students into classes after they have been registered.</p>
          <% if (dashboard.classGroups.length === 0 || dashboard.students.length === 0) { %>
            <div class="banner error">Create at least one class and one student first.</div>
          <% } else { %>
            <form method="post" action="/admin/classes/<%= dashboard.classGroups[0].id %>/students" class="stack" data-class-assignment-form>
              <label>
                <span>Class</span>
                <select name="classGroupIdProxy" required onchange="this.form.action='/admin/classes/' + this.value + '/students'">
                  <% dashboard.classGroups.forEach((classGroup) => { %>
                    <option value="<%= classGroup.id %>"><%= classGroup.name %> · <%= classGroup.teacherName %></option>
                  <% }) %>
                </select>
              </label>
              <label>
                <span><%= tenant.terminology.student %></span>
                <select name="studentId" required>
                  <% dashboard.students.forEach((student) => { %>
                    <option value="<%= student.id %>"><%= student.fullName %></option>
                  <% }) %>
                </select>
              </label>
              <button class="primary-button" type="submit">Assign student</button>
            </form>
          <% } %>
        </article>

        <article class="form-card">
          <h2>Link guardian to student</h2>
          <p class="muted">Use this when one parent has multiple children, or when a child has more than one guardian.</p>
          <% if (dashboard.guardians.length === 0 || dashboard.students.length === 0) { %>
            <div class="banner error">Create at least one <%= tenant.terminology.parent.toLowerCase() %> and one student first.</div>
          <% } else { %>
            <form method="post" action="/admin/students/<%= dashboard.students[0].id %>/guardians" class="stack">
              <label>
                <span><%= tenant.terminology.student %></span>
                <select name="studentIdProxy" required onchange="this.form.action='/admin/students/' + this.value + '/guardians'">
                  <% dashboard.students.forEach((student) => { %>
                    <option value="<%= student.id %>"><%= student.fullName %></option>
                  <% }) %>
                </select>
              </label>
              <label>
                <span><%= tenant.terminology.parent %></span>
                <select name="guardianUserId" required>
                  <% dashboard.guardians.forEach((guardian) => { %>
                    <option value="<%= guardian.id %>"><%= guardian.name %></option>
                  <% }) %>
                </select>
              </label>
              <label>
                <span>Relationship</span>
                <input type="text" name="relationship" value="guardian" required />
              </label>
              <button class="primary-button" type="submit">Link guardian</button>
            </form>
          <% } %>
        </article>
      </section>

      <section class="forms-grid">
        <article class="form-card">
          <h2>Manage users</h2>
          <p class="muted">Edit roles and remove access. Permanent delete is only available when the user has no linked records.</p>
          <div class="admin-edit-list">
            <% dashboard.users.filter((account) => account.role !== "pending").forEach((account) => { %>
              <article class="admin-edit-item">
                <form method="post" action="/admin/users/<%= account.id %>" class="stack">
                  <div class="compact-grid">
                    <label>
                      <span>Name</span>
                      <input type="text" name="name" value="<%= account.name %>" required />
                    </label>
                    <label>
                      <span>Email</span>
                      <input type="email" name="email" value="<%= account.email %>" required />
                    </label>
                    <label>
                      <span>Role</span>
                      <select name="role" required>
                        <option value="admin" <%= account.role === "admin" ? "selected" : "" %>>Admin</option>
                        <option value="teacher" <%= account.role === "teacher" ? "selected" : "" %>><%= tenant.terminology.teacher %></option>
                        <option value="parent" <%= account.role === "parent" ? "selected" : "" %>><%= tenant.terminology.parent %></option>
                      </select>
                    </label>
                  </div>
                  <div class="action-row">
                    <span>
                      <span class="badge <%= account.active ? "badge-neutral" : "badge-warning" %>"><%= account.active ? "active" : "inactive" %></span>
                      <span class="table-subtext"><%= account.dependencyCount %> linked record(s)</span>
                    </span>
                    <button class="primary-button" type="submit">Save user</button>
                  </div>
                </form>

                <div class="action-row">
                  <% if (account.id !== user.id) { %>
                    <form method="post" action="/admin/users/<%= account.id %>/active">
                      <input type="hidden" name="active" value="<%= account.active ? "0" : "1" %>" />
                      <button class="ghost-button" type="submit"><%= account.active ? "Deactivate" : "Reactivate" %></button>
                    </form>
                    <% if (account.dependencyCount === 0) { %>
                      <form method="post" action="/admin/users/<%= account.id %>/delete">
                        <button class="link-button danger-button" type="submit">Delete permanently</button>
                      </form>
                    <% } else { %>
                      <span class="muted">Remove linked students/classes before permanent delete.</span>
                    <% } %>
                  <% } else { %>
                    <span class="muted">This is your account. Another admin must manage it.</span>
                  <% } %>
                </div>
              </article>
            <% }) %>
            <% if (dashboard.users.filter((account) => account.role !== "pending").length === 0) { %>
              <p class="muted">No active admin-managed users yet.</p>
            <% } %>
          </div>
        </article>

        <article class="form-card">
          <h2>Classes</h2>
          <div class="admin-edit-list">
            <% dashboard.classGroups.forEach((classGroup) => { %>
              <article class="admin-edit-item">
                <form method="post" action="/admin/classes/<%= classGroup.id %>" class="stack">
                  <div class="compact-grid">
                    <label>
                      <span>Class name</span>
                      <input type="text" name="name" value="<%= classGroup.name %>" required />
                    </label>
                    <label>
                      <span><%= tenant.terminology.teacher %></span>
                      <select name="teacherUserId" required>
                        <% dashboard.teachers.forEach((teacher) => { %>
                          <option value="<%= teacher.id %>" <%= teacher.id === classGroup.teacherUserId ? "selected" : "" %>><%= teacher.name %></option>
                        <% }) %>
                      </select>
                    </label>
                  </div>
                  <label>
                    <span>Description</span>
                    <textarea name="description" rows="2"><%= classGroup.description %></textarea>
                  </label>
                  <div class="action-row">
                    <span class="muted"><%= classGroup.studentCount %> assigned <%= tenant.terminology.student.toLowerCase() %>(s)</span>
                    <button class="primary-button" type="submit">Save class</button>
                  </div>
                </form>
                <form method="post" action="/admin/classes/<%= classGroup.id %>/delete" class="action-row">
                  <span class="muted">Deleting a class removes the group assignment only. Student records remain.</span>
                  <button class="link-button danger-button" type="submit">Delete class</button>
                </form>
              </article>
            <% }) %>
            <% if (dashboard.classGroups.length === 0) { %>
              <p class="muted">No classes created yet.</p>
            <% } %>
          </div>
        </article>
      </section>

      <section class="form-card form-card-wide">
        <h2>Manage students</h2>
        <p class="muted">Admins can update student details, remove class assignments, and unlink additional guardians.</p>
        <div class="admin-edit-list">
          <% dashboard.students.forEach((student) => { %>
            <article class="admin-edit-item">
              <form method="post" action="/admin/students/<%= student.id %>" class="stack">
                <div class="compact-grid">
                  <label>
                    <span>First name</span>
                    <input type="text" name="firstName" value="<%= student.firstName %>" required />
                  </label>
                  <label>
                    <span>Last name</span>
                    <input type="text" name="lastName" value="<%= student.lastName %>" required />
                  </label>
                  <label>
                    <span><%= tenant.terminology.teacher %></span>
                    <select name="teacherUserId" required>
                      <% dashboard.teachers.forEach((teacher) => { %>
                        <option value="<%= teacher.id %>" <%= teacher.id === student.teacherUserId ? "selected" : "" %>><%= teacher.name %></option>
                      <% }) %>
                    </select>
                  </label>
                  <label>
                    <span>Monthly fee</span>
                    <input type="number" name="monthlyFee" min="0" step="0.01" value="<%= student.monthlyFee %>" required />
                  </label>
                  <label>
                    <span>Current surah</span>
                    <input type="text" name="currentSurah" value="<%= student.currentSurah %>" required />
                  </label>
                  <label>
                    <span>Current ayah</span>
                    <input type="text" name="currentAyah" value="<%= student.currentAyah %>" required />
                  </label>
                </div>
                <div class="action-row">
                  <strong><%= student.fullName %></strong>
                  <button class="primary-button" type="submit">Save student</button>
                </div>
              </form>

              <div class="management-block">
                <h3>Class assignments</h3>
                <% if (student.classAssignments.length === 0) { %>
                  <p class="muted">Not assigned to a class.</p>
                <% } %>
                <div class="pill-list">
                  <% student.classAssignments.forEach((classGroup) => { %>
                    <form method="post" action="/admin/classes/<%= classGroup.id %>/students/<%= student.id %>/remove" class="pill-form">
                      <span><%= classGroup.name %></span>
                      <button class="link-button danger-button" type="submit">Remove</button>
                    </form>
                  <% }) %>
                </div>
              </div>

              <div class="management-block">
                <h3><%= tenant.terminology.parent %> links</h3>
                <% if (student.guardians.length === 0) { %>
                  <p class="muted">No guardians linked.</p>
                <% } %>
                <div class="pill-list">
                  <% student.guardians.forEach((guardian) => { %>
                    <form method="post" action="/admin/students/<%= student.id %>/guardians/<%= guardian.id %>/remove" class="pill-form">
                      <span><%= guardian.name %> · <%= guardian.relationship %><%= guardian.isPrimary ? " · primary" : "" %></span>
                      <button class="link-button danger-button" type="submit">Remove</button>
                    </form>
                  <% }) %>
                </div>
              </div>
            </article>
          <% }) %>
          <% if (dashboard.students.length === 0) { %>
            <p class="muted">No students registered yet.</p>
          <% } %>
        </div>
      </section>
    </main>
  </body>
</html>
